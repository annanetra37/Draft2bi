# --- Database ---
# Dev default: SQLite (zero external services). The Prisma schema is written to
# be Postgres-portable — for production, switch the datasource provider to
# "postgresql" and point DATABASE_URL at your Postgres instance (e.g. Railway).
DATABASE_URL="file:./dev.db"

# --- Extraction (the "magic") ---
# When ANTHROPIC_API_KEY is set, the Claude vision adapter is used to read
# document photos. When unset, PaperLens falls back to a deterministic mock
# extractor so the whole pipeline runs end-to-end with no API key.
# ANTHROPIC_API_KEY="sk-ant-..."
EXTRACTOR_MODEL="claude-opus-4-8"

# Force the mock extractor even if a key is present (useful for demos/tests).
# EXTRACTOR="mock"

# --- Review thresholds ---
# Fields with confidence below this are routed to the human review queue.
REVIEW_CONFIDENCE_THRESHOLD="0.85"
