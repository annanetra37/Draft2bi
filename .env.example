# --- Database (PostgreSQL) ---
# Local dev (matches docker-compose.yml):
DATABASE_URL="postgresql://paperlens:paperlens@localhost:5432/paperlens?schema=public"
#
# On Railway: add a PostgreSQL plugin, then set this service variable to a
# reference so it tracks the plugin automatically:
#   DATABASE_URL = ${{ Postgres.DATABASE_URL }}

# --- Extraction (the "magic") ---
# When ANTHROPIC_API_KEY is set, the Claude vision adapter reads document photos.
# When unset, PaperLens falls back to a deterministic mock extractor so the whole
# pipeline runs end-to-end with no API key.
# ANTHROPIC_API_KEY="sk-ant-..."
EXTRACTOR_MODEL="claude-opus-4-8"

# Force the mock extractor even if a key is present (useful for demos/tests).
# EXTRACTOR="mock"

# --- Review thresholds ---
# Fields with confidence below this are routed to the human review queue.
REVIEW_CONFIDENCE_THRESHOLD="0.85"

# --- Image storage ---
# Real photos are written here and served at /uploads. On Railway, mount a
# persistent volume at this path so uploads survive redeploys. (Demo SVG pages
# are stored as data URLs in the DB and need no disk.)
# UPLOAD_DIR="/app/public/uploads"

# Public base URL — used when the Claude extractor must fetch a stored image by
# URL. Set to your Railway domain in production, e.g. https://paperlens.up.railway.app
# NEXT_PUBLIC_BASE_URL="http://localhost:3000"
